     "name": "stdout",
     "output_type": "stream",
     "text": [
      "it's a cold day\n"
     ]
    }
   ],
   "source": [
    "temp = 12\n",
    "\n",
    "if temp > 30:\n",
    "    print(\"it's a hot day\")\n",
    "elif 20 <= temp <= 30:\n",
    "    print(\"it's a nice day\")\n",
    "else:\n",
    "    print(\"it's a cold day\")        "
   ]
  }
